# ── Gemini / LLM ──────────────────────────────────────
GEMINI_API_KEY=           # Required for LLM analysis
LLM_MODEL=gemini-2.0-flash
LLM_MAX_TOKENS=1000

# ── ChromaDB / RAG ───────────────────────────────────
CHROMA_PERSIST_DIR=./chroma_db
CHROMA_COLLECTION_NAME=sql_cases
RAG_TOP_K=3               # Number of similar cases to retrieve

# ── SQLite ───────────────────────────────────────────
SQLITE_DB_PATH=./sqlops_guardian.db

# ── Logging ──────────────────────────────────────────
LOG_LEVEL=INFO             # DEBUG, INFO, WARNING, ERROR
DEBUG=false                # Enable debug mode 

# ── Severity Behavior (optional overrides) ───────────
# BLOCK_ON=DELETE_WITHOUT_WHERE,UPDATE_WITHOUT_WHERE,DROP_TABLE
# WARN_ON=SELECT_STAR,MISSING_LIMIT,LEADING_WILDCARD_LIKE
